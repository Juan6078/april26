<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Juan Manuel Floría · Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #071a10;
    --surface: #0d2318;
    --border: #163d26;
    --accent: #e8c547;
    --accent2: #4ecdc4;
    --text: #e8e8f0;
    --muted: #7ecfa0;
    --card: #0b1f14;
    --light-blue: #7dd3fc;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: linear-gradient(160deg, #071a10 0%, #0b2518 40%, #071e14 70%, #040f09 100%);
    background-attachment: fixed;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 4rem;
    background: rgba(7,26,16,0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-left {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .nav-logo {
    font-family: 'DM Mono', monospace;
    font-size: 0.88rem;
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .nav-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    opacity: 0.9;
  }
  .hero-date-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    color: var(--muted);
    margin-bottom: 0.4rem;
  }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    font-family: 'DM Mono', monospace;
    font-size: 0.83rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }

  /* HERO */
  #hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 8rem 4rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 50%, rgba(232,197,71,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(78,205,196,0.04) 0%, transparent 50%);
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .hero-content { position: relative; z-index: 1; }

  .hero-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .hero-tag::before {
    content: '';
    display: block;
    width: 40px;
    height: 1px;
    background: var(--accent);
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  h1 .last-name {
    color: var(--accent);
    display: block;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: #7dd3fc;
    line-height: 1.6;
    max-width: 420px;
    margin-bottom: 2.5rem;
  }

  .hero-roles {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  .role-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    padding: 0.35rem 0.9rem;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 2px;
  }
  .role-tag.highlight {
    border-color: var(--accent);
    color: var(--accent);
  }
  .role-tag.highlight2 {
    border-color: var(--accent2);
    color: var(--accent2);
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.85rem 2rem;
    background: var(--accent);
    color: #0a0a0f;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    font-weight: 500;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.85; }

  .btn-outline {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.85rem 2rem;
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

  /* HERO RIGHT PANEL */
  .hero-right {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    width: 100%;
    max-width: 380px;
  }

  .stat-box {
    background: var(--card);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .stat-number {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* QR CODE */
  .hero-qr-wrapper {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 380px;
    background: var(--card);
    border: 1px solid var(--border);
    padding: 0.9rem 1.2rem;
  }
  .hero-qr-wrapper img {
    width: 72px;
    height: 72px;
    object-fit: contain;
    flex-shrink: 0;
    filter: invert(1) sepia(1) saturate(3) hue-rotate(170deg) brightness(0.85);
  }
  .hero-qr-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .hero-qr-text span:first-child {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .hero-qr-text span:last-child {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--muted);
  }

  .contact-strip {
    width: 100%;
    max-width: 380px;
    background: var(--card);
    border: 1px solid var(--border);
    padding: 1.2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    color: #7dd3fc;
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact-item:hover { color: var(--accent); }
  .contact-item svg { flex-shrink: 0; }

  /* SECTIONS */
  section {
    padding: 6rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .section-number {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.2em;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .section-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-text p {
    color: var(--muted);
    line-height: 1.8;
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }

  .about-text strong { color: var(--text); font-weight: 500; }

  .about-highlights {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
  }

  .highlight-item {
    background: var(--card);
    padding: 1.2rem 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .hi-icon {
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--muted);
    margin-top: 0.35rem;
  }

  .hi-content h4 {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }

  .hi-content p {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
  }

  /* EXPERIENCE */
  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, var(--accent), var(--border), transparent);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }

  .timeline-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

  .timeline-dot {
    position: absolute;
    left: -2.3rem;
    top: 0.35rem;
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
  }

  .timeline-dot.dim {
    background: var(--border);
  }

  .timeline-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
  }

  .timeline-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: rgba(232,197,71,0.08);
    padding: 0.2rem 0.7rem;
    border-radius: 2px;
  }

  .timeline-company {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  .timeline-item h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .timeline-points {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .timeline-points li {
    font-size: 0.88rem;
    color: var(--muted);
    padding-left: 1rem;
    position: relative;
    line-height: 1.6;
  }

  .timeline-points li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent2);
    font-size: 0.7rem;
    top: 0.15rem;
  }

  /* SKILLS */
  .skills-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .skill-category {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 1.8rem;
  }

  .skill-category h4 {
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    padding: 0.35rem 0.8rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 2px;
    letter-spacing: 0.05em;
  }

  .skill-tag.hot {
    border-color: rgba(232,197,71,0.3);
    color: var(--accent);
    background: rgba(232,197,71,0.05);
  }

  .skill-tag.cool {
    border-color: rgba(78,205,196,0.3);
    color: var(--accent2);
    background: rgba(78,205,196,0.05);
  }

  /* EDUCATION */
  .edu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }

  .edu-card {
    background: var(--card);
    padding: 1.8rem;
    position: relative;
    overflow: hidden;
  }

  .edu-card::before {
    content: attr(data-year);
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  .edu-grade {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    background: rgba(232,197,71,0.08);
    padding: 0.2rem 0.6rem;
    margin-bottom: 0.8rem;
  }

  .edu-card h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .edu-card p {
    font-size: 0.78rem;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
  }

  /* CERTIFICATIONS */
  .cert-list {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.8rem;
  }

  .cert-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-left: 2px solid var(--accent2);
    padding: 0.8rem 1rem;
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.4;
  }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    padding: 3rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .footer-copy {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  /* REDUCE GAP BETWEEN HERO AND ABOUT */
  #hero { padding-top: 5rem; padding-bottom: 2rem; }
  #about { padding-top: 0; }

  /* DIVIDER */
  .full-divider {
    width: 100%;
    height: 1px;
    background: var(--border);
    margin: 0 4rem;
    width: calc(100% - 8rem);
    display: block;
  }

  /* ANIMATE */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .fade-up { animation: fadeUp 0.7s ease forwards; }
  .fade-up-2 { animation: fadeUp 0.7s 0.15s ease forwards; opacity: 0; }
  .fade-up-3 { animation: fadeUp 0.7s 0.3s ease forwards; opacity: 0; }
  .fade-up-4 { animation: fadeUp 0.7s 0.45s ease forwards; opacity: 0; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); }

  /* HAMBURGER MENU */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
    z-index: 200;
  }
  .nav-hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--muted);
    transition: all 0.3s;
  }
  .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-hamburger.open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-hamburger { display: flex; }
    .nav-links {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(7,26,16,0.97);
      backdrop-filter: blur(16px);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
      z-index: 150;
    }
    .nav-links.open { display: flex; }
    .nav-links a { font-size: 1.1rem; letter-spacing: 0.2em; }
    #hero { grid-template-columns: 1fr; padding: 7rem 1.5rem 3rem; }
    .hero-right { align-items: flex-start; margin-top: 3rem; }
    .stats-grid, .contact-strip { max-width: 100%; }
    section { padding: 4rem 1.5rem; }
    .about-grid, .edu-grid { grid-template-columns: 1fr; }
    .cert-list { grid-template-columns: 1fr 1fr; }
    footer { flex-direction: column; gap: 1rem; text-align: center; padding: 2rem 1.5rem; }
    .full-divider { margin: 0 1.5rem; width: calc(100% - 3rem); }
  }

  @media (max-width: 480px) {
    h1 { font-size: clamp(2.4rem, 10vw, 3.5rem); }
    .hero-subtitle { font-size: 1rem; }
    .hero-roles { gap: 0.4rem; }
    .role-tag { font-size: 0.6rem; padding: 0.3rem 0.7rem; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .stat-number { font-size: 2.2rem; }
    .cert-list { grid-template-columns: 1fr; }
    .section-header { gap: 1rem; }
    h2 { font-size: clamp(1.6rem, 6vw, 2.2rem); }
    .skills-container { grid-template-columns: 1fr; }
    .edu-card { padding: 1.2rem; }
    .timeline { padding-left: 1.5rem; }
    .timeline-dot { left: -1.8rem; }
    .about-grid { gap: 2rem; }
    .hero-photo-wrapper { max-width: 120px; }
    .hero-photo { max-width: 105px; height: 175px; }
    .hero-cta { flex-direction: column; }
    .btn-primary, .btn-outline { text-align: center; }
    .contact-strip { padding: 1rem; }
    .contact-item { font-size: 0.72rem; }
  }

  /* PROFILE PHOTO */
.hero-photo-wrapper {
  display: inline-block;
  position: relative;
  margin-right: auto;
  margin-left: -9px;
  line-height: 0;
}

.hero-photo-wrapper::before {
  content: '';
  position: absolute;
  inset: 0;
  border: 1px solid var(--accent);
  opacity: 0.5;
  pointer-events: none;
  z-index: 1;
}

.hero-photo-wrapper::after {
  display: none;
}

.hero-photo {
  width: 140px;
  height: 210px;
  object-fit: cover;
  object-position: 40% 15%;
  display: block;
  filter: grayscale(20%) contrast(1.05);
}


/* FOTO + QR LADO A LADO */
.hero-photo-qr-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 1.4rem;
}

.hero-qr-solo {
  display: flex;
  align-items: flex-start;
  margin-top: 0.5rem;
}

.hero-qr-solo img {
  width: 80px;
  height: 80px;
  object-fit: contain;
  filter: invert(1) sepia(1) saturate(3) hue-rotate(170deg) brightness(0.85);
}


/* ── CERT CAROUSEL IMAGE ── */
.cc-wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 1.5rem 4rem 2.5rem;
}
.cc-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.58rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--accent);
  display: flex;
  align-items: center;
  gap: 0.7rem;
  margin-bottom: 1rem;
}
.cc-label::before {
  content: '';
  width: 24px; height: 1px;
  background: var(--accent);
  display: block;
}
.cc-viewport { overflow: hidden; }
.cc-track {
  display: flex;
  transition: transform 0.4s cubic-bezier(.25,.46,.45,.94);
  will-change: transform;
}
.cc-card {
  flex-shrink: 0;
  width: calc(100% / 3);
  box-sizing: border-box;
  padding: 0 6px;
  display: flex;
  flex-direction: column;
  cursor: pointer;
}
.cc-card img {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  object-position: center top;
  display: block;
  border: 1px solid var(--border);
  transition: border-color 0.2s, opacity 0.2s;
}
.cc-card:hover img {
  border-color: var(--accent);
