<script>
  // ── CERT CAROUSEL ──
  (function(){
    const track = document.getElementById('ccTrack');
    const prev  = document.getElementById('ccPrev');
    const next  = document.getElementById('ccNext');
    const dots  = document.getElementById('ccDots');
    const cards = track.children;
    const total = cards.length;
    let cur = 0;

    function vis(){
      if(window.innerWidth <= 480) return 1;
      if(window.innerWidth <= 900) return 2;
      return 3;
    }
    function pages(){ return Math.ceil(total / vis()); }

    function buildDots(){
      dots.innerHTML = '';
      for(let i=0; i<pages(); i++){
        const b = document.createElement('button');
        b.className = 'cc-dot' + (i===cur?' on':'');
        b.addEventListener('click', ()=>go(i));
        dots.appendChild(b);
      }
    }

    function go(idx){
      const v = vis(); const p = pages();
      cur = Math.max(0, Math.min(idx, p-1));
      const vp = document.getElementById('ccViewport');
      const cardW = vp.offsetWidth / v;
      track.style.transform = 'translateX(-' + (cur * v * cardW) + 'px)';
      [...dots.children].forEach((d,i)=>d.classList.toggle('on', i===cur));
      prev.disabled = cur===0;
      next.disabled = cur>=p-1;
    }

    function init(){
      const v = vis();
      [...cards].forEach(c=>{ c.style.width = 'calc(100% / '+v+')'; c.style.flexShrink='0'; });
      buildDots();
      go(cur > pages()-1 ? 0 : cur);
    }

    prev.addEventListener('click', ()=>go(cur-1));
    next.addEventListener('click', ()=>go(cur+1));
    init();
    let rt;
    window.addEventListener('resize', ()=>{ clearTimeout(rt); rt=setTimeout(init,150); });
  })();
</script>
